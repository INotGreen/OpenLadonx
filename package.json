{
  "name": "ladonx",
  "private": true,
  "version": "0.7.68",
  "type": "module",
  "scripts": {
    "sync:material-icons": "node tools/sync-material-icons.mjs",
    "sync:tauri-resources": "node tools/sync-tauri-resources.mjs",
    "sync:tauri-resources:all": "node tools/sync-tauri-resources.mjs --all",
    "icon:update": "sh tools/update-icon.sh",
    "postinstall": "npm run sync:material-icons && npm run sync:tauri-resources",
    "predev": "npm run sync:material-icons && npm run sync:tauri-resources",
    "dev": "vite",
    "prebuild": "npm run sync:material-icons && npm run sync:tauri-resources",
    "build": "tsc && vite build",
    "buildupload": "python3 tools/parallel_release.py",
    "build:desktop": "bash tools/build-desktop.sh",
    "build:desktop:all": "bash tools/build-desktop.sh",
    "build:appimage": "NO_STRIP=1 tauri build --bundles appimage",
    "doctor": "sh tools/doctor.sh",
    "doctor:strict": "sh tools/doctor.sh --strict",
    "doctor:win": "node tools/doctor.mjs --strict",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:ds": "eslint . --ext .ts,.tsx",
    "morning-briefing:run": "sh tools/morning-briefing.sh",
    "codemod:modal-shell": "node tools/codemods/modal-shell-codemod.mjs",
    "codemod:panel-shell": "node tools/codemods/panel-shell-codemod.mjs",
    "codemod:toast-shell": "node tools/codemods/toast-shell-codemod.mjs",
    "codemod:ds:dry": "npm run codemod:modal-shell -- --dry-run && npm run codemod:panel-shell -- --dry-run && npm run codemod:toast-shell -- --dry-run",
    "codemod:ds": "npm run codemod:modal-shell && npm run codemod:panel-shell && npm run codemod:toast-shell",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "react:devtools": "react-devtools",
    "pretauri:dev": "npm run sync:material-icons && npm run sync:tauri-resources",
    "tauri:dev": "npm run sync:tauri-resources && cargo build --manifest-path src-tauri/Cargo.toml --bin ladonx_daemon && npm run doctor:strict && tauri dev",
    "pretauri:build": "npm run sync:material-icons && npm run sync:tauri-resources",
    "tauri:build": "npm run sync:tauri-resources && npm run doctor:strict && tauri build",
    "pretauri:dev:win": "npm run sync:material-icons && npm run sync:tauri-resources",
    "tauri:dev:win": "npm run sync:tauri-resources && cargo build --manifest-path src-tauri/Cargo.toml --bin ladonx_daemon --target x86_64-pc-windows-gnu && npm run doctor:win && tauri dev --config src-tauri/tauri.windows.conf.json",
    "pretauri:build:win": "npm run sync:material-icons && npm run sync:tauri-resources",
    "tauri:build:win": "npm run sync:tauri-resources && npm run doctor:win && tauri build --config src-tauri/tauri.windows.conf.json"
  },
  "dependencies": {
    "@lexical/react": "^0.44.0",
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.0.6",
    "@sentry/react": "^10.36.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "~2.5.3",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tiptap/pm": "^3.27.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "fractional-indexing": "^3.2.0",
    "framer-motion": "^12.42.0",
    "i18next": "^26.2.0",
    "lexical": "^0.44.0",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.5.15",
    "pptx-preview": "^1.0.7",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tauri-plugin-liquid-glass-api": "^0.1.6",
    "tldraw": "^5.1.1",
    "vscode-material-icons": "^0.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@react-dev-inspector/babel-plugin": "^2.0.1",
    "@react-dev-inspector/vite-plugin": "^2.0.1",
    "@tauri-apps/cli": "~2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/i18next": "^12.1.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^27.0.1",
    "react-dev-inspector": "^2.0.1",
    "react-devtools": "^7.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
