{
  "app": {
    "windows": [
      {
        "title": "LadonX",
        "width": 1200,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "dragDropEnabled": true,
        "titleBarStyle": "Visible",
        "hiddenTitle": false,
        "transparent": false,
        "devtools": true,
        "windowEffects": null
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": false
  }
}
